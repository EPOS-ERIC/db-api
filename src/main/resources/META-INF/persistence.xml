			<!-- Query optimization -->
			<property name="eclipselink.query-results-cache" value="true"/>
			<property name="eclipselink.query-results-cache.size" value="500"/>

			<!-- Logging (WARNING level for production) -->
			<property name="eclipselink.logging.level" value="WARNING"/>
			<property name="eclipselink.logging.parameters" value="false"/>

			<!-- Performance monitoring -->
			<property name="eclipselink.jpa.performance-monitor" value="QueryMonitor"/>

			<!-- DDL generation (set to 'none' for production) -->
