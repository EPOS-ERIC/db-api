		<properties>

			<!-- ================= ECLIPSELINK PERFORMANCE TUNING ================= -->

			<!-- Batch writing for better performance -->
			<property name="eclipselink.jdbc.batch-writing" value="JDBC"/>
			<property name="eclipselink.jdbc.batch-writing.size" value="25"/>

			<!-- Connection pooling optimization -->
			<property name="eclipselink.connection-pool.default.connection-creation-failure-policy" value="retry"/>
			<property name="eclipselink.connection-pool.default.fail-on-wait" value="false"/>

			<!-- Cache settings -->
			<property name="eclipselink.cache.shared.default" value="true"/>
			<property name="eclipselink.cache.type.default" value="SoftWeak"/>
			<property name="eclipselink.cache.size.default" value="1000"/>

			<!-- 
			  Disable L2 cache for join tables to prevent IllegalMonitorStateException
			  and cache contention under concurrent access. Join tables are frequently
			  modified and benefit little from caching while causing thread safety issues.
			-->
			<!-- Category joins -->
			<property name="eclipselink.cache.shared.model.CategoryHastopconcept" value="false"/>
			<property name="eclipselink.cache.shared.model.CategoryIspartof" value="false"/>
			
			<!-- DataProduct joins -->
